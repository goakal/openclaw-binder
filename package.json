{
  "name": "@openclaw/binder",
  "version": "2026.5.6.8",
  "private": true,
  "description": "OpenClaw Binder channel plugin",
  "type": "module",
  "scripts": {
    "build": "npx tsc || true"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.5.6"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "setupEntry": "./dist/setup-entry.js",
    "channel": {
      "id": "binder",
      "label": "Binder",
      "selectionLabel": "Binder (webhook)",
      "detailLabel": "Binder",
      "docsPath": "/channels/binder",
      "docsLabel": "binder",
      "blurb": "Binder group chat via @mention webhooks.",
      "aliases": [
        "bindr"
      ],
      "order": 80
    },
    "compat": {
      "pluginApi": ">=2026.5.6",
      "minGatewayVersion": "2026.5.6"
    },
    "build": {
      "openclawVersion": "2026.5.6",
      "pluginSdkVersion": "2026.5.6"
    }
  }
}
